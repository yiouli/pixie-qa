[
    {
        "id": "all_pass",
        "description": "All test functions pass — exit 0, console shows passed count, scorecard generated",
        "test_files": {
            "test_simple.py": "def test_alpha():\n    assert 1 + 1 == 2\n\ndef test_beta():\n    assert 'hello'.upper() == 'HELLO'\n"
        },
        "argv": [],
        "expected_exit_code": 0,
        "console_contains": [
            "test_simple.py::test_alpha",
            "test_simple.py::test_beta",
            "2 passed",
            "\u2713"
        ],
        "console_not_contains": [
            "failed",
            "error"
        ],
        "scorecard_html_contains": [
            "test_simple.py::test_alpha",
            "test_simple.py::test_beta",
            "2/2 tests passed",
            "PASS"
        ]
    },
    {
        "id": "some_fail",
        "description": "One test fails via AssertionError — exit 1, console shows failure, scorecard has FAIL",
        "test_files": {
            "test_mixed.py": "def test_good():\n    assert True\n\ndef test_bad():\n    raise AssertionError('expected 42 but got 0')\n"
        },
        "argv": [],
        "expected_exit_code": 1,
        "console_contains": [
            "test_mixed.py::test_good",
            "test_mixed.py::test_bad",
            "1 passed",
            "1 failed",
            "\u2717"
        ],
        "console_not_contains": [
            "error"
        ],
        "scorecard_html_contains": [
            "test_mixed.py::test_good",
            "test_mixed.py::test_bad",
            "1/2 tests passed",
            "PASS",
            "FAIL"
        ]
    },
    {
        "id": "test_error",
        "description": "Test raises an unexpected exception (not AssertionError) — exit 1, console shows errors",
        "test_files": {
            "test_boom.py": "def test_explode():\n    raise RuntimeError('something went wrong')\n"
        },
        "argv": [],
        "expected_exit_code": 1,
        "console_contains": [
            "test_boom.py::test_explode",
            "1 errors",
            "\u2717",
            "something went wrong"
        ],
        "console_not_contains": [
            "passed"
        ],
        "scorecard_html_contains": [
            "test_boom.py::test_explode",
            "ERROR",
            "something went wrong"
        ]
    },
    {
        "id": "filter_match",
        "description": "Using -k filter selects only matching tests",
        "test_files": {
            "test_filter.py": "def test_apple():\n    assert True\n\ndef test_banana():\n    assert True\n\ndef test_cherry():\n    assert True\n"
        },
        "argv": [
            "-k",
            "banana"
        ],
        "expected_exit_code": 0,
        "console_contains": [
            "test_filter.py::test_banana",
            "1 passed"
        ],
        "console_not_contains": [
            "test_apple",
            "test_cherry"
        ],
        "scorecard_html_contains": [
            "test_filter.py::test_banana",
            "1/1 tests passed"
        ]
    },
    {
        "id": "filter_no_match",
